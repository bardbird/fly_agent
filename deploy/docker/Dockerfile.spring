FROM maven:3.9.9-eclipse-temurin-17 AS build

ARG APP_MODULE
WORKDIR /workspace

COPY . .
RUN test -n "$APP_MODULE"
RUN mvn -pl "$APP_MODULE" -am package -DskipTests
RUN jar_file="$(find "$APP_MODULE/target" -maxdepth 1 -type f -name '*.jar' ! -name '*sources.jar' ! -name '*javadoc.jar' | head -n 1)" \
    && test -n "$jar_file" \
    && cp "$jar_file" /tmp/app.jar

FROM eclipse-temurin:17-jre-noble

LABEL com.fly-agent.stack="app"

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        docker.io \
        git \
        openssh-client \
        python3 \
        python3-pip \
        python3-venv \
        unzip \
    && rm -rf /var/lib/apt/lists/*
RUN git config --system --add safe.directory /opt/fly-agent/swe-agent

WORKDIR /app

COPY --from=build /tmp/app.jar /app/app.jar
COPY tools/swe-pro-production /app/tools/swe-pro-production

RUN mkdir -p /data/fly-agent/swe-output /data/applogs/xxl-job/jobhandler /opt/fly-agent/swe-agent /tmp/fly-agent-home /app/logs \
    && chmod 1777 /tmp/fly-agent-home /data/fly-agent/swe-output /data/applogs/xxl-job/jobhandler /app/logs

ENV JAVA_OPTS="" \
    SWE_TOOLKIT_ROOT=/app/tools/swe-pro-production \
    SWE_PRODUCTION_ROOT=/data/fly-agent/swe-output \
    SWE_AGENT_ROOT=/opt/fly-agent/swe-agent

EXPOSE 8080 8082 9999

ENTRYPOINT ["sh", "-c", "exec java $JAVA_OPTS -jar /app/app.jar"]
