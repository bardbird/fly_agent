FROM node:22-bookworm-slim AS build

WORKDIR /workspace/fly-agent-web

COPY fly-agent-web/package*.json ./
RUN npm ci

COPY fly-agent-web/ ./
RUN npm run build

FROM nginx:1.27-alpine

LABEL com.fly-agent.stack="app"

COPY deploy/docker/nginx/default.conf /etc/nginx/conf.d/default.conf
COPY --from=build /workspace/fly-agent-web/dist /usr/share/nginx/html

EXPOSE 80
