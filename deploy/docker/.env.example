# Copy this file to deploy/docker/.env before deploying.

COMPOSE_PROJECT_NAME=fly-agent
FLY_AGENT_IMAGE_PREFIX=fly-agent
IMAGE_TAG=local

# Published ports on the host.
WEB_PORT=6677
SERVER_PORT=8080
TASK_PORT=8082
XXL_JOB_EXECUTOR_PORT=9999

# Host-side persistent data and external tool locations.
FLY_AGENT_DATA_DIR=/data/fly-agent
SWE_OUTPUT_HOST_DIR=/data/fly-agent/swe-output
FLY_AGENT_LOG_DIR=/data/fly-agent/logs
XXL_JOB_LOG_DIR=/data/fly-agent/logs/xxl-job
SWE_AGENT_HOST_ROOT=/opt/fly-agent/swe-agent
DOCKER_SOCK=/var/run/docker.sock

# Runtime identity for server/task containers. scripts/docker-deploy.sh fills
# these from the deployment user and Docker socket when missing.
FLY_AGENT_RUN_UID=1000
FLY_AGENT_RUN_GID=1000
DOCKER_GID=988

# SWE-agent bootstrap. The deploy script clones the repo when missing and
# rebuilds the venv when sweagent is unavailable.
SWE_AGENT_BOOTSTRAP=true
SWE_AGENT_GIT_URL=https://github.com/SWE-agent/SWE-agent.git
SWE_AGENT_GIT_REF=main
SWE_AGENT_AUTO_UPDATE=false

# Spring profile and external infrastructure.
SPRING_PROFILES_ACTIVE=dev
SPRING_DATASOURCE_URL=jdbc:mysql://51.161.15.134:3307/fly_agent?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=123456789
SPRING_REDIS_HOST=51.161.15.134
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=homeX

# XXL-Job Admin should be reachable from inside containers.
XXL_JOB_ADMIN_ADDRESSES=http://51.161.15.134:9090/xxl-job-admin
XXL_JOB_ACCESS_TOKEN=default_token
# Optional: set this when XXL-Job Admin must call a specific public executor URL.
XXL_JOB_EXECUTOR_ADDRESS=

# Runtime secrets. Keep real values only in deploy/docker/.env.
GITHUB_TOKEN=
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-5
SWE_QWEN_TOKEN=
SWE_OPUS_TOKEN=

# Model and SWE-agent runtime tuning.
SWE_QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
SWE_QWEN_MODEL=qwen3.6-flash
SWE_OPUS_BASE_URL=https://ai.yiqiu.dev/v1
SWE_OPUS_MODEL=claude-opus-4-7
SWE_AGENT_MAX_STEPS=20
SWE_OPUS_MAX_STEPS_SCHEDULE=180,10
SWE_MODEL_TIMEOUT_SECONDS=3600

# JVM options.
SERVER_JAVA_OPTS=-Xms512m -Xmx1024m
TASK_JAVA_OPTS=-Xms512m -Xmx1024m
